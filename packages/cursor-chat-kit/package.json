{
  "name": "@lovable/cursor-chat-kit",
  "version": "0.2.0",
  "private": false,
  "description": "Reusable Cursor background-agent chat for Lovable TanStack Start projects.",
  "type": "module",
  "sideEffects": ["styles.css"],
  "files": ["dist", "migrations", "README.md", "styles.css"],
  "scripts": {
    "build": "tsup src/index.ts src/types.ts src/server/index.ts src/react/index.ts --format esm --dts --clean --splitting --tsconfig tsconfig.json",
    "prepack": "bun run build"
  },
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./server": { "types": "./dist/server/index.d.ts", "import": "./dist/server/index.js" },
    "./react": { "types": "./dist/react/index.d.ts", "import": "./dist/react/index.js" },
    "./types": { "types": "./dist/types.d.ts", "import": "./dist/types.js" },
    "./styles.css": "./styles.css"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.0",
    "@assistant-ui/react-markdown": "^0.14.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": ">=0.500.0 <1",
    "mermaid": "^11.15.0",
    "remark-gfm": "^4.0.0",
    "shiki": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.0.0 || ^4.0.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "@types/node": "^22.16.5",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "@assistant-ui/core": "0.2.12",
    "@assistant-ui/store": "0.2.14",
    "@assistant-ui/tap": "0.6.1"
  },
  "publishConfig": { "access": "restricted" }
}
